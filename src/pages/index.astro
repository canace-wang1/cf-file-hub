---
let files = [];
let error = null;

try {
  // 直接读取所有文件
  const result = await process.env.DB.prepare("SELECT * FROM files").all();
  files = result.results;
} catch (err) {
  // 捕获错误，方便排查
  error = err.message;
}
---

<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>D1 调试页面</title>
  <style>
    body { font-family: system-ui; padding: 2rem; max-width: 800px; margin: 0 auto; }
    .error { background: #fee; color: #a00; padding: 1rem; border-radius: 8px; margin-bottom: 1rem; }
    .file { border: 1px solid #eee; padding: 1rem; border-radius: 8px; margin-bottom: 0.5rem; }
  </style>
</head>
<body>
  <h1>D1 数据库调试</h1>

  {#if error}
    <div class="error">❌ 读取数据库失败: {error}</div>
  {/if}

  <h3>数据库文件数量: {files.length}</h3>

  {#each files as file}
    <div class="file">
      <p><strong>{file.name}</strong></p>
      <p>分类: {file.category} | 类型: {file.file_type}</p>
      <p>R2路径: {file.r2_key}</p>
      <a href={`https://ppt.test.yaozi1350.cc/${file.r2_key}`} target="_blank">下载文件</a>
    </div>
  {/each}
</body>
</html>